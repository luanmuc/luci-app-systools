# 旁路由模式
msgid "Side Route Mode"
msgstr "旁路由模式"

msgid "One-click switch between normal router mode and side route mode. Side route mode allows the router to work as a bypass gateway for proxy and special network processing."
msgstr "一键切换正常路由模式和旁路由模式。旁路由模式下，路由器作为旁路网关，用于代理和特殊网络处理。"

